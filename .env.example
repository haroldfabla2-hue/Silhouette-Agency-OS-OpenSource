# ═══════════════════════════════════════════════════════════════
# SILHOUETTE AGENCY OS — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# DO NOT COMMIT .env.local TO VERSION CONTROL.
#
# MINIMUM TO START: Add at least ONE key under "LLM Providers".
# Everything else is optional — the system degrades gracefully.
# ═══════════════════════════════════════════════════════════════

# ─── System ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
DEBUG=false

# ─── LLM Providers (AT LEAST ONE REQUIRED) ───────────────────
# The orchestrator cannot think without at least one provider.
# Free tiers are available for Gemini and Groq.

# API Key for internal services
API_KEY=

# Google Gemini — recommended, free tier available
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq — fast inference, free tier available
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — multi-model access, free models available
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DeepSeek — coding specialist
DEEPSEEK_API_KEY=

# Minimax — optional
MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# Ollama — local inference, no key needed
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Communication Channels (Optional) ───────────────────────
# Choose how to interact with the orchestrator.
# If none are set, use the web UI (http://localhost:5173)
# or the REST API / WebSocket directly.

# Telegram — create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Discord — get token from Discord Developer Portal
DISCORD_BOT_TOKEN=

# WhatsApp — uses QR code scan on first start (no token needed)
# WHATSAPP_SESSION_PATH=./data/whatsapp_session

# ─── Data & Persistence (Optional — auto-degrades without) ───
# Without these, the system uses SQLite + in-memory fallbacks.
# Install via Docker: docker-compose up -d

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis (Persistent Cache & PubSub)
REDIS_URL=redis://localhost:6379

# ─── Media & Voice (Optional) ─────────────────────────────────
# Only needed for image/video generation and voice synthesis.

# OpenAI — DALL-E 3 image generation and TTS
OPENAI_API_KEY=

# ElevenLabs — text-to-speech and voice cloning
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Replicate — image/video generation (SVD, Veo, NanoBanana)
# REPLICATE_API_TOKEN=
# VEO_MODEL_ID=google/veo-3.1
# NANOBANANA_MODEL_ID=google/nano-banana-pro

# ImagineArt — fallback image generation
# IMAGINE_ART_KEY=

# Unsplash — real stock photography
# UNSPLASH_ACCESS_KEY=

# Local voice engine (AllTalk/RVC)
# VOICE_ENGINE_URL=http://localhost:8100

# ─── Google Services (Optional) ──────────────────────────────
# Google Drive integration
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/v1/drive/callback
# GOOGLE_DRIVE_FOLDER_ID=

# Google Custom Search (for research tools)
# GOOGLE_API_KEY=
# GOOGLE_CX_ID=

# ZhipuAI — Chinese LLM (semicolon-separated key pool)
# ZHIPU_API_KEYS=key1;key2;key3

# ─── Self-Evolution & GitHub Integration (Optional) ──────────
# Required only if you want the system to push code changes automatically.
GITHUB_TOKEN=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=Silhouette-Agency-OS
# GITHUB_BASE_BRANCH=main

# ─── Security (Optional) ─────────────────────────────────────
# If set, all API requests must include this token as a Bearer header.
# Leave empty to disable auth (recommended for local development).
# SILHOUETTE_API_TOKEN=

# ─── CORS (Optional) ─────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# SILHOUETTE_CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── Debug Flags (Optional) ──────────────────────────────────
# Set to any value to enable verbose logging per subsystem.
# DEBUG_CURIOSITY=1
# DEBUG_HUB_STRENGTH=1
# DEBUG_LLM_GATEWAY=1
# NO_SANDBOX=true
